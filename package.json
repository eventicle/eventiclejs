{
  "name": "@eventicle/eventiclejs",
  "version": "1.1.10",
  "description": "A powerful TypeScript framework for building event-driven, domain-driven applications with Event Sourcing and CQRS patterns",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/eventicle/eventiclejs.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build-ts": "tsc",
    "watch-ts": "tsc -w",
    "integration-test": "NODE_ENV=dev jest --testRegex /test/.*\\.integration.ts$",
    "unit-test": "NODE_ENV=dev jest --testRegex /test/.*\\.test.ts$ ",
    "test": "yarn unit-test && yarn integration-test",
    "lint": "eslint . --ext .ts --fix",
    "api": "yarn tsc && api-extractor run;api-documenter yaml -i tmp/api -o tmp/api-yaml;api-documenter-yaml-to-antora-asciidoc asciidoc -i tmp/api-yaml"
  },
  "peerDependencies": {
    "@eventicle/eventicle-utilities": "^0.0.18",
    "bullmq": ">=5 <6"
  },
  "dependencies": {
    "@types/crypto-js": "^4.1.1",
    "@types/node-cron": "^3.0.6",
    "@types/serialize-error": "^4.0.1",
    "asynchronous-local-storage": "^1.0.2",
    "avsc": "^5.7.9",
    "cron-parser": "^5.4.0",
    "crypto-js": "^4.1.1",
    "deep-equal": "^2.1.0",
    "fast-safe-stringify": "^2.1.1",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "node-cron": "^4.2.1",
    "serialize-error": "^7.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.18.3",
    "xstate": "^4.35.1"
  },
  "devDependencies": {
    "@eventicle/eventicle-utilities": "^0.0.19",
    "@microsoft/api-documenter": "^7.28.1",
    "@microsoft/api-extractor": "^7.55.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.21",
    "api-documenter-yaml-to-antora-asciidoc": "^0.0.0-11",
    "bullmq": "^5.65.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "typescript-bundle": "^1.0.18"
  },
  "author": "Team Eventicle",
  "license": "Apache-2.0"
}
